{
  "name": "@kirbah/mcp-youtube",
  "version": "1.1.9",
  "mcpName": "io.github.kirbah/mcp-youtube",
  "description": "YouTube MCP server for token-optimized, structured data using the YouTube Data API v3.",
  "main": "dist/index.js",
  "type": "module",
  "bin": {
    "mcp-youtube": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "start:client": "tsx ./src/index.ts",
    "inspector": "npx @modelcontextprotocol/inspector tsx ./src/index.ts",
    "clean": "rimraf dist",
    "lint": "node --max-old-space-size=4096 node_modules/eslint/bin/eslint.js .",
    "test": "jest",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "keywords": [
    "mcp",
    "youtube",
    "youtube-api",
    "claude",
    "anthropic",
    "model-context-protocol",
    "ai",
    "llm",
    "language-model",
    "tools"
  ],
  "author": "Kiryl Bahdanau",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kirbah/mcp-youtube.git"
  },
  "bugs": {
    "url": "https://github.com/kirbah/mcp-youtube/issues"
  },
  "homepage": "https://github.com/kirbah/mcp-youtube#readme",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "googleapis": "^171.4.0",
    "mongodb": "^7.0.0",
    "tsx": "^4.20.4",
    "youtube-transcript-plus": "^2.0.0",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/jest": "30.0.0",
    "@types/node": "^25.5.2",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.4.0",
    "jest": "30.4.2",
    "jest-junit": "^17.0.0",
    "prettier": "^3.6.2",
    "rimraf": "^6.0.1",
    "ts-jest": "^29.4.9",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.58.1"
  },
  "engines": {
    "node": ">=20.12.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
